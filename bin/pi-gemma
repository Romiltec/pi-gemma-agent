#!/usr/bin/env bash
# pi-gemma — Pi coding agent ottimizzato per un modello locale piccolo (default: Gemma 4 12B via vLLM).
# Applica le 3 leve che fanno rendere un 12B: provider giusto, ragionamento profondo, method system-prompt.
# Override via env: PI_GEMMA_MODEL, PI_GEMMA_THINKING, PI_GEMMA_PROVIDER.
set -euo pipefail

# Risolvi la dir reale dello script (gestisce i symlink dell'install).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"; [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
HERE="$(cd -P "$(dirname "$SOURCE")/.." >/dev/null 2>&1 && pwd)"

MODEL="${PI_GEMMA_MODEL:-gemma-4-12b-it}"
THINKING="${PI_GEMMA_THINKING:-high}"
PROVIDER="${PI_GEMMA_PROVIDER:-vllm-anthropic}"

exec pi --provider "$PROVIDER" --model "$MODEL" --thinking "$THINKING" \
  --append-system-prompt "$(cat "$HERE/setup/method.md")" "$@"
